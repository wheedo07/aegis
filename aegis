#!/usr/bin/env bash
# aegis - Aegis 통합 관리 CLI
set -euo pipefail

AEGIS_VERSION=0.0.1
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

source "$SCRIPT_DIR/lib/util.sh"
source "$SCRIPT_DIR/lib/install.agent.sh"

usage() {
    cat <<EOF
aegis v$AEGIS_VERSION - Apache 요청 보안 에이전트 관리 도구

사용법:
  aegis <명령> [대상]

명령:
  install agent     Apache 모듈(aegis-mod) 빌드 및 설치
  install server    aegis-server 설치 (미구현)

  help              이 도움말 출력
  version           버전 출력

예시:
  sudo aegis install agent
EOF
}

CMD="${1:-}"
case "$CMD" in
    install)
        TARGET="${2:-}"
        case "$TARGET" in
            agent)
                install_agent
            ;;
            server)
                die "install server 는 아직 구현되지 않았습니다."
            ;;
            *)
                error "'aegis install agent' 또는 'aegis install server' 를 사용하세요.";
                usage;
                exit 1
            ;;
        esac
        ;;
    version)
        echo "aegis v$AEGIS_VERSION"
    ;;
    help|--help|-h|"")
        usage
    ;;
    *)
        error "알 수 없는 명령: $CMD"
        usage
        exit 1
    ;;
esac